{
  "manifest_version": 3,
  "name": "Browser Defender",
  "version": "1.0",
  "description": "Комплексное расширение для защиты персональных данных и обеспечения безопасности в сети, объединяющее в себе криптографию AES-256, защищенный буфер обмена, анти-фишинг и автоматическую блокировку механизмов сетевой слежки.",
  "permissions": [
    "browsingData",
    "storage",
    "declarativeNetRequest",
    "scripting",
    "activeTab",
    "clipboardWrite"
  ],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": { "default_popup": "popup.html" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["inject.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "block_list",
      "enabled": true,
      "path": "rules.json"
    }]
  }
}